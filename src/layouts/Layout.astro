---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Cyzen Technology',
  description = 'Senior Product Security Engineer · OSCP certified · Penetration testing, secure code review, and architecture review for financial, entertainment, and healthcare companies.',
} = Astro.props;

const path = Astro.url.pathname;

const nav = [
  { href: '/',        label: 'Home'    },
  { href: '/about',   label: 'About'   },
  { href: '/dorks',   label: 'Dorks'   },
  { href: '/tools',   label: 'Tools'   },
  { href: '/contact', label: 'Contact' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-zinc-950 text-zinc-100 min-h-screen antialiased flex flex-col">

    <header class="border-b border-zinc-800 bg-zinc-950/80 backdrop-blur-md sticky top-0 z-50">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between gap-4">
        <a href="/" class="font-mono font-bold text-green-400 text-lg tracking-tight shrink-0">
          <span class="text-zinc-600">&gt;_</span> cyzen
        </a>
        <nav class="flex items-center gap-1">
          {nav.map(({ href, label }) => {
            const isActive = href === '/' ? path === '/' || path === '' : path.startsWith(href);
            return (
              <a
                href={href}
                class={`px-3 py-1.5 rounded-md text-sm font-medium transition-colors ${
                  isActive
                    ? 'text-green-400 bg-green-500/10'
                    : 'text-zinc-400 hover:text-zinc-100 hover:bg-zinc-800'
                }`}
              >
                {label}
              </a>
            );
          })}
        </nav>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-zinc-800 py-6 mt-16">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 flex flex-wrap gap-4 items-center justify-between text-xs text-zinc-600">
        <span>© 2026 Cyzen Technology · AppSec &amp; Web Development</span>
        <a href="mailto:cyzen.technology@gmail.com" class="hover:text-zinc-400 transition">
          cyzen.technology@gmail.com
        </a>
      </div>
    </footer>

  </body>
</html>
