---
import Layout from '../layouts/Layout.astro';

const FORMSPREE_ID = 'xaqzjege';
---

<Layout title="Contact — Cyzen Technology">
  <section class="max-w-4xl mx-auto px-4 sm:px-6 pt-12 pb-8">
    <h1 class="text-3xl font-bold mb-2">Contact</h1>
    <p class="text-zinc-400 mb-10 text-sm">
      Have a project in mind or need a security assessment? Reach out below.
    </p>

    <div class="grid sm:grid-cols-3 gap-4 mb-8">
      <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-5">
        <p class="text-xs font-semibold uppercase tracking-wider text-zinc-500 mb-2">Email</p>
        <a
          href="mailto:cyzen.technology@gmail.com"
          class="text-green-400 font-mono text-sm hover:text-green-300 transition break-all"
        >
          cyzen.technology@gmail.com
        </a>
      </div>
      <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-5">
        <p class="text-xs font-semibold uppercase tracking-wider text-zinc-500 mb-2">Response Time</p>
        <p class="text-zinc-300 text-sm">Within 24–48 hours</p>
      </div>
      <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-5">
        <p class="text-xs font-semibold uppercase tracking-wider text-zinc-500 mb-2">Services</p>
        <p class="text-zinc-300 text-sm">AppSec · Pentesting · Web Dev</p>
      </div>
    </div>

    <!-- Contact form -->
    <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-6 sm:p-8">
      <h2 class="text-lg font-semibold text-zinc-100 mb-6">Send a message</h2>

      <!-- Success state -->
      <div id="form-success" class="hidden text-center py-10">
        <p class="text-3xl mb-3">✓</p>
        <p class="text-zinc-100 font-semibold mb-1">Message sent</p>
        <p class="text-zinc-400 text-sm">Thanks for reaching out. I'll get back to you within 24–48 hours.</p>
      </div>

      <!-- Error state -->
      <div id="form-error" class="hidden mb-4 px-4 py-3 bg-red-500/10 border border-red-500/20 rounded-lg text-sm text-red-400">
        Something went wrong. Please try again or email directly at
        <a href="mailto:cyzen.technology@gmail.com" class="underline underline-offset-2">cyzen.technology@gmail.com</a>.
      </div>

      <form id="contact-form" class="space-y-4">
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label for="name" class="block text-xs font-medium text-zinc-400 uppercase tracking-wider mb-1.5">
              Name
            </label>
            <input
              id="name"
              name="name"
              type="text"
              required
              placeholder="Your name"
              autocomplete="name"
              class="w-full bg-zinc-950 border border-zinc-700 rounded-lg px-4 py-2.5 text-sm text-zinc-100 placeholder-zinc-600 focus:outline-none focus:border-green-500/60 focus:ring-1 focus:ring-green-500/30 transition"
            />
          </div>
          <div>
            <label for="email" class="block text-xs font-medium text-zinc-400 uppercase tracking-wider mb-1.5">
              Email
            </label>
            <input
              id="email"
              name="email"
              type="email"
              required
              placeholder="you@example.com"
              autocomplete="email"
              class="w-full bg-zinc-950 border border-zinc-700 rounded-lg px-4 py-2.5 text-sm text-zinc-100 placeholder-zinc-600 focus:outline-none focus:border-green-500/60 focus:ring-1 focus:ring-green-500/30 transition"
            />
          </div>
        </div>

        <div>
          <label for="subject" class="block text-xs font-medium text-zinc-400 uppercase tracking-wider mb-1.5">
            Subject
          </label>
          <input
            id="subject"
            name="subject"
            type="text"
            placeholder="e.g. Web application pentest scope"
            class="w-full bg-zinc-950 border border-zinc-700 rounded-lg px-4 py-2.5 text-sm text-zinc-100 placeholder-zinc-600 focus:outline-none focus:border-green-500/60 focus:ring-1 focus:ring-green-500/30 transition"
          />
        </div>

        <div>
          <label for="message" class="block text-xs font-medium text-zinc-400 uppercase tracking-wider mb-1.5">
            Message
          </label>
          <textarea
            id="message"
            name="message"
            rows="5"
            required
            placeholder="Describe your project or what you need help with..."
            class="w-full bg-zinc-950 border border-zinc-700 rounded-lg px-4 py-2.5 text-sm text-zinc-100 placeholder-zinc-600 focus:outline-none focus:border-green-500/60 focus:ring-1 focus:ring-green-500/30 transition resize-none"
          ></textarea>
        </div>

        <div class="flex justify-end">
          <button
            id="submit-btn"
            type="submit"
            class="px-6 py-2.5 bg-green-500/10 hover:bg-green-500/20 border border-green-500/20 hover:border-green-500/40 text-green-400 rounded-lg text-sm font-medium transition disabled:opacity-50 disabled:cursor-not-allowed"
          >
            Send message →
          </button>
        </div>
      </form>
    </div>

  </section>
</Layout>

<script define:vars={{ FORMSPREE_ID }}>
  const form      = document.getElementById('contact-form');
  const submitBtn = document.getElementById('submit-btn');
  const success   = document.getElementById('form-success');
  const error     = document.getElementById('form-error');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    error.classList.add('hidden');
    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending…';

    try {
      const res = await fetch(`https://formspree.io/f/${FORMSPREE_ID}`, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (res.ok) {
        form.classList.add('hidden');
        success.classList.remove('hidden');
      } else {
        throw new Error('bad response');
      }
    } catch {
      error.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send message →';
    }
  });
</script>
