---
import Layout from '../layouts/Layout.astro';

const DORKS_URL = '/dorks';
---

<Layout title="Tools — Cyzen Technology">
  <section class="max-w-4xl mx-auto px-4 sm:px-6 pt-12 pb-8">
    <h1 class="text-3xl font-bold mb-2">Tools</h1>
    <p class="text-zinc-400 mb-10 text-sm">Open-source security tools and references.</p>

    <div class="grid gap-4">

      <!-- Google Dorks for Bug Bounty -->
      <div class="bg-zinc-900 border border-zinc-800 border-l-4 border-l-green-500 rounded-xl overflow-hidden hover:border-zinc-700 transition-colors">
        <div class="p-6">
          <div class="flex items-start justify-between gap-4 flex-wrap mb-3">
            <div>
              <div class="flex items-center gap-2 mb-1">
                <span class="text-xl">🔍</span>
                <h2 class="text-lg font-semibold text-zinc-100">Google Dorks for Bug Bounty</h2>
              </div>
              <p class="text-xs text-zinc-500 font-mono">
                v2.0 · 100+ dorks · OWASP Top 10 2025 · built on{' '}
                <a
                  href="https://github.com/TakSec/google-dorks-bug-bounty"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-zinc-400 hover:text-zinc-200 underline underline-offset-2 transition"
                >
                  TakSec/google-dorks-bug-bounty
                </a>
              </p>
            </div>
            <span class="shrink-0 text-xs px-2 py-0.5 bg-green-500/10 text-green-400 border border-green-500/20 rounded font-mono">
              open source
            </span>
          </div>

          <p class="text-sm text-zinc-400 leading-relaxed mb-4">
            A comprehensive Google dork reference for bug bounty hunters and penetration testers.
            Enter your target domain to auto-populate all queries. Filter by category, severity, and
            OWASP Top 10 2025 classification, then launch directly in Google or DuckDuckGo with one click.
          </p>

          <div class="flex gap-2 flex-wrap mb-5">
            {[
              'Credentials', 'PII & SSN', 'Admin Panels', 'API Discovery',
              'Cloud Storage', 'Code Leaks', 'OWASP 2025', 'SAST / OSINT',
            ].map((tag) => (
              <span class="text-xs bg-zinc-800 text-zinc-400 px-2 py-1 rounded">{tag}</span>
            ))}
          </div>

          <div class="bg-zinc-950 border border-zinc-800 rounded-lg p-4 mb-5 font-mono text-xs text-zinc-400 leading-relaxed">
            <p class="text-green-400 mb-1"># Example dork — auto-populated with your domain</p>
            <p>site:<span class="text-zinc-300">example.com</span> filetype:env | inurl:"/.env" | inurl:"/.env.local"</p>
          </div>

          <div class="flex gap-3 flex-wrap">
            <a
              href={DORKS_URL}
              class="px-4 py-2 bg-green-500/10 hover:bg-green-500/20 border border-green-500/20 hover:border-green-500/40 text-green-400 rounded-lg text-sm font-medium transition"
            >
              Launch Tool →
            </a>
            <a
              href="https://github.com/TakSec/google-dorks-bug-bounty"
              target="_blank"
              rel="noopener noreferrer"
              class="px-4 py-2 bg-zinc-800 hover:bg-zinc-700 border border-zinc-700 text-zinc-300 rounded-lg text-sm font-medium transition"
            >
              Original Repo ↗
            </a>
          </div>

          <!-- Attribution -->
          <p class="mt-4 text-xs text-zinc-600">
            Original dork list by{' '}
            <a
              href="https://github.com/TakSec/google-dorks-bug-bounty"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-zinc-400 transition underline underline-offset-2"
            >
              TakSec
            </a>
            {' '}·{' '}
            additional sources:{' '}
            <a
              href="https://github.com/lutfumertceylan/top25-parameter"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-zinc-400 transition underline underline-offset-2"
            >
              lutfumertceylan/top25-parameter
            </a>
            {' '}·{' '}
            <a
              href="https://github.com/Proviesec/google-dorks"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-zinc-400 transition underline underline-offset-2"
            >
              Proviesec/google-dorks
            </a>
          </p>
        </div>
      </div>

    </div>
  </section>
</Layout>
