---
import Layout from '../layouts/Layout.astro';

const expertise = [
  {
    title: 'Penetration Testing',
    items: [
      'Web Application Pentest (OSCP certified)',
      'API Security Testing',
      'OWASP Top 10 Coverage',
      'Business Logic & Auth Flaws',
    ],
  },
  {
    title: 'Application Security',
    items: [
      'SAST / Secure Code Review',
      'Threat Modeling',
      'Security Architecture Review',
      'Bug Bounty Hunting',
    ],
  },
  {
    title: 'Secure Development',
    items: [
      'Full-Stack Web Development',
      'Secure-by-Default Configuration',
      'SDLC Security Integration',
      'Developer Security Guidance',
    ],
  },
];
---

<Layout title="About — Cyzen Technology">
  <section class="max-w-4xl mx-auto px-4 sm:px-6 pt-12 pb-8">

    <!-- Profile card -->
    <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-6 sm:p-8 flex flex-col sm:flex-row items-center gap-6 sm:gap-10 mb-8">
      <img
        src="/img/Dugan.jpg"
        alt="Dugan Zabran"
        class="w-32 h-32 sm:w-36 sm:h-36 rounded-full object-cover border-4 border-green-500/30 shadow-lg shrink-0"
      />
      <div>
        <h1 class="text-2xl sm:text-3xl font-bold text-zinc-100 mb-1">Dugan Zabran</h1>
        <p class="text-green-400 font-mono text-sm mb-4">Senior Product Security Engineer · OSCP</p>
        <p class="text-zinc-400 leading-relaxed text-sm sm:text-base">
          Hi there! I'm Dugan, a Senior Product Security Engineer and OSCP certified penetration tester
          with experience securing applications across financial, entertainment, and healthcare industries.
          I serve as a trusted advisor for security teams, helping organizations build secure products,
          reduce risk, and mature their security posture from the ground up.
        </p>
      </div>
    </div>

    <!-- Expertise grid -->
    <div class="grid sm:grid-cols-3 gap-4">
      {expertise.map(({ title, items }) => (
        <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-5">
          <h3 class="font-semibold text-zinc-100 mb-3 text-sm">{title}</h3>
          <ul class="space-y-2">
            {items.map((item) => (
              <li class="flex items-start gap-2 text-xs text-zinc-400">
                <span class="text-green-500 font-mono mt-0.5 shrink-0">▶</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-8 text-center">
      <a
        href="/contact"
        class="inline-flex items-center gap-2 px-6 py-3 bg-green-500/10 hover:bg-green-500/20 border border-green-500/20 hover:border-green-500/40 text-green-400 rounded-lg text-sm font-medium transition"
      >
        Get in touch →
      </a>
    </div>

  </section>
</Layout>
