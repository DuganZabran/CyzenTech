---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    icon: '🔍',
    title: 'Web Application Penetration Testing',
    desc: 'Manual, OSCP-methodology testing of web apps and APIs — OWASP Top 10, business logic flaws, auth bypass, injection, and beyond. Delivered with a clear, actionable report.',
  },
  {
    icon: '🐛',
    title: 'Bug Bounty Support',
    desc: 'Target reconnaissance, OSINT, Google dorking, and structured testing methodology to maximize bug bounty ROI — whether scoping a new program or hunting high-severity findings.',
  },
  {
    icon: '🔎',
    title: 'Secure Code Review',
    desc: 'SAST-assisted manual code review to find vulnerabilities before they ship — injection flaws, insecure deserialization, broken access control, and hardcoded secrets.',
  },
  {
    icon: '🏗️',
    title: 'Security Architecture Review',
    desc: 'Design-level threat modeling and architecture analysis to catch systemic risks early — auth flows, trust boundaries, data handling, and third-party integrations.',
  },
  {
    icon: '⚡',
    title: 'Secure Web Development',
    desc: 'Custom websites and web applications built with security baked in from the start — modern frameworks, secure-by-default configuration, and developer security guidance.',
  },
  {
    icon: '📋',
    title: 'Security Program Consulting',
    desc: 'Practical guidance for teams launching or maturing their AppSec program — policy, SDLC integration, tooling selection, and developer security training.',
  },
];
---

<Layout>
  <!-- Hero -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 pt-20 pb-12">
    <div class="inline-flex items-center gap-2 bg-green-500/10 border border-green-500/20 rounded-full px-3 py-1 text-xs text-green-400 mb-6">
      <span class="w-1.5 h-1.5 bg-green-400 rounded-full animate-pulse"></span>
      OSCP Certified · Senior Product Security Engineer
    </div>
    <h1 class="text-4xl sm:text-5xl font-bold mb-4 leading-tight">
      A trusted advisor<br />
      <span class="bg-gradient-to-r from-green-400 to-emerald-300 bg-clip-text text-transparent">
        for security teams.
      </span>
    </h1>
    <p class="text-zinc-400 text-lg max-w-2xl mb-8 leading-relaxed">
      Cyzen Technology delivers application security and web development services for companies
      in financial, entertainment, and healthcare. Penetration testing, code review, secure
      architecture, and full-stack builds — all with an offensive security mindset.
    </p>
    <div class="flex gap-3 flex-wrap">
      <a
        href="/contact"
        class="px-5 py-2.5 bg-green-500/10 hover:bg-green-500/20 border border-green-500/20 hover:border-green-500/40 text-green-400 rounded-lg text-sm font-medium transition"
      >
        Get in touch →
      </a>
      <a
        href="/about"
        class="px-5 py-2.5 bg-zinc-800 hover:bg-zinc-700 border border-zinc-700 text-zinc-100 rounded-lg text-sm font-medium transition"
      >
        About Dugan
      </a>
    </div>
  </section>

  <!-- Services -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-8">
    <h2 class="text-xs font-semibold uppercase tracking-wider text-zinc-500 mb-4">Services</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {services.map(({ icon, title, desc }) => (
        <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-5 hover:border-zinc-700 transition-colors">
          <div class="text-2xl mb-3">{icon}</div>
          <h3 class="font-semibold text-zinc-100 mb-2 text-sm leading-snug">{title}</h3>
          <p class="text-xs text-zinc-400 leading-relaxed">{desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Featured Tool -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-8">
    <h2 class="text-xs font-semibold uppercase tracking-wider text-zinc-500 mb-4">Featured Tool</h2>
    <div class="bg-zinc-900 border border-zinc-800 border-l-4 border-l-green-500 rounded-xl p-6 hover:border-zinc-700 transition-colors">
      <div class="flex items-start justify-between gap-4 flex-wrap">
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-2">
            <span class="text-xl">🔍</span>
            <h3 class="font-semibold text-zinc-100">Google Dorks for Bug Bounty</h3>
            <span class="text-xs px-2 py-0.5 bg-green-500/10 text-green-400 border border-green-500/20 rounded font-mono">
              open source
            </span>
          </div>
          <p class="text-sm text-zinc-400 leading-relaxed mb-4">
            A research-backed Google dork reference for bug bounty and penetration testing. Enter a target
            domain to auto-populate all queries. Filter by category, severity, and OWASP Top 10 2025
            classification — then launch directly in Google or DuckDuckGo.
          </p>
          <div class="flex gap-2 flex-wrap">
            {['Credentials', 'PII', 'Admin Panels', 'API Discovery', 'Cloud Storage', 'OWASP 2025'].map((tag) => (
              <span class="text-xs bg-zinc-800 text-zinc-400 px-2 py-1 rounded">{tag}</span>
            ))}
          </div>
        </div>
        <a
          href="/tools"
          class="shrink-0 px-4 py-2.5 bg-green-500/10 hover:bg-green-500/20 border border-green-500/20 hover:border-green-500/40 text-green-400 rounded-lg text-sm font-medium transition whitespace-nowrap"
        >
          View Tools →
        </a>
      </div>
    </div>
  </section>
</Layout>
