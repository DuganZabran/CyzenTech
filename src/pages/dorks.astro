---
import Layout from '../layouts/Layout.astro';
import { dorks, categoryMeta, severityMeta, owaspMeta, type Category, type Severity, type OwaspId } from '../data/dorks';

const totalDorks = dorks.length;
const allCategories = Object.keys(categoryMeta) as Category[];
const categoryCounts = Object.fromEntries(
  allCategories.map((cat) => [cat, dorks.filter((d) => d.category === cat).length])
) as Record<Category, number>;
const allSeverities: Severity[] = ['critical', 'high', 'medium', 'low', 'info'];
const severityCounts = Object.fromEntries(
  allSeverities.map((s) => [s, dorks.filter((d) => d.severity === s).length])
) as Record<Severity, number>;
const allOwaspIds = Object.keys(owaspMeta) as OwaspId[];
const owaspCounts = Object.fromEntries(
  allOwaspIds.map((id) => [id, dorks.filter((d) => d.owasp?.includes(id)).length])
) as Record<OwaspId, number>;
---

<Layout title="Google Dorks — Cyzen Technology" description="Research-backed Google dorks for bug bounty hunting and penetration testing. Filter by category, severity, and OWASP Top 10 2025.">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 pb-16">

    <!-- Hero -->
    <section class="pt-10 pb-8 text-center">
      <div class="inline-flex items-center gap-2 bg-green-500/10 border border-green-500/20 rounded-full px-3 py-1 text-xs text-green-400 mb-4">
        <span class="w-1.5 h-1.5 bg-green-400 rounded-full animate-pulse"></span>
        Research-backed · {totalDorks} dorks · {Object.keys(categoryMeta).length} categories
      </div>
      <h1 class="text-3xl sm:text-4xl font-bold mb-3 bg-gradient-to-r from-green-400 to-emerald-300 bg-clip-text text-transparent">
        Bug Bounty Dork Reference
      </h1>
      <p class="text-zinc-400 max-w-2xl mx-auto text-sm sm:text-base mb-4">
        Enter your target domain to auto-populate all dorks. Click any query to open it in Google,
        or copy it to your clipboard. Filter by category and severity to focus on what matters.
      </p>
      <!-- Search -->
      <div class="relative max-w-xs mx-auto">
        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-zinc-500 text-sm select-none">/</span>
        <input
          id="search-input"
          type="search"
          placeholder="Search dorks…"
          autocomplete="off"
          class="w-full bg-zinc-900 border border-zinc-800 rounded-lg pl-7 pr-3 py-2 text-sm text-zinc-100 placeholder-zinc-600 focus:outline-none focus:border-green-500/60 focus:ring-1 focus:ring-green-500/30 transition"
        />
      </div>
    </section>

    <!-- Domain input -->
    <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-5 mb-6">
      <label for="domain-input" class="block text-xs font-medium text-zinc-400 uppercase tracking-wider mb-2">
        Target Domain
      </label>
      <div class="flex gap-3 flex-wrap sm:flex-nowrap">
        <div class="relative flex-1">
          <input
            id="domain-input"
            type="text"
            placeholder="example.com"
            autocomplete="off"
            spellcheck="false"
            class="w-full bg-zinc-950 border border-zinc-700 rounded-lg px-4 py-3 text-sm font-mono text-zinc-100 placeholder-zinc-600 focus:outline-none focus:border-green-500/60 focus:ring-1 focus:ring-green-500/30 transition"
          />
        </div>
        <button
          id="clear-domain"
          class="px-4 py-3 bg-zinc-800 hover:bg-zinc-700 border border-zinc-700 rounded-lg text-xs text-zinc-400 hover:text-zinc-200 transition font-medium whitespace-nowrap"
        >
          Reset
        </button>
      </div>
      <p class="mt-2 text-xs text-zinc-600">
        Searches run against the first domain entered. Multiple comma-separated entries are for same-org scope tracking only (e.g. <span class="font-mono text-zinc-500">corp.com, subsidiary.io</span>)
      </p>
    </div>

    <!-- Filters -->
    <div class="space-y-3 mb-6">
      <div class="flex gap-2 flex-wrap">
        <button class="category-btn active px-3 py-1.5 rounded-full text-xs font-medium border transition" data-category="all">
          All <span class="opacity-60 ml-1">{totalDorks}</span>
        </button>
        {allCategories.map((cat) => (
          <button class="category-btn px-3 py-1.5 rounded-full text-xs font-medium border transition" data-category={cat}>
            {categoryMeta[cat].label}
            <span class="opacity-60 ml-1">{categoryCounts[cat]}</span>
          </button>
        ))}
      </div>

      <div class="flex gap-2 flex-wrap items-center">
        <button class="severity-btn active px-2.5 py-1 rounded-md text-xs font-medium border transition" data-severity="all">
          Any severity
        </button>
        {allSeverities.map((sev) => (
          <button
            class={`severity-btn px-2.5 py-1 rounded-md text-xs font-medium border transition ${severityMeta[sev].badge}`}
            data-severity={sev}
          >
            {severityMeta[sev].label}
            <span class="opacity-60 ml-1">{severityCounts[sev]}</span>
          </button>
        ))}
        <span class="ml-auto text-xs text-zinc-500">
          Showing <span id="visible-count-bar" class="text-zinc-300 font-medium">{totalDorks}</span> dorks
        </span>
      </div>

      <div class="flex gap-2 flex-wrap items-center">
        <span class="text-xs text-zinc-600 font-medium uppercase tracking-wider shrink-0">OWASP 2025</span>
        <button class="owasp-btn active px-2.5 py-1 rounded-md text-xs font-medium border transition" data-owasp="all">
          Any
        </button>
        {allOwaspIds.map((id) => (
          <button
            class="owasp-btn px-2.5 py-1 rounded-md text-xs font-medium border transition"
            data-owasp={id}
            title={owaspMeta[id].label}
          >
            {id}
            <span class="opacity-60 ml-1">{owaspCounts[id]}</span>
          </button>
        ))}
      </div>
    </div>

    <!-- Dork grid -->
    <div id="dork-grid" class="grid grid-cols-1 lg:grid-cols-2 gap-3">
      {dorks.map((dork) => (
        <article
          class={`dork-card bg-zinc-900 border border-zinc-800 rounded-xl border-l-4 ${severityMeta[dork.severity].border} overflow-hidden transition-all hover:border-zinc-700`}
          data-category={dork.category}
          data-severity={dork.severity}
          data-needs-domain={String(dork.needsDomain)}
          data-original-query={dork.query}
          data-title={dork.title.toLowerCase()}
          data-description={dork.description.toLowerCase()}
          data-tags={dork.tags.join(' ')}
          data-owasp={(dork.owasp ?? []).join(' ')}
        >
          <div class="p-4">
            <div class="flex items-start justify-between gap-2 mb-2">
              <h3 class="text-sm font-semibold text-zinc-100 leading-snug">{dork.title}</h3>
              <span class={`shrink-0 text-xs px-2 py-0.5 rounded font-medium ${severityMeta[dork.severity].badge}`}>
                {severityMeta[dork.severity].label}
              </span>
            </div>

            <div class="flex items-center gap-1.5 flex-wrap mb-3">
              <span class="text-xs text-zinc-500 bg-zinc-800 px-2 py-0.5 rounded">
                {categoryMeta[dork.category].label}
              </span>
              {(dork.owasp ?? []).map((id) => (
                <span
                  class="text-xs text-violet-400 bg-violet-500/10 border border-violet-500/20 px-2 py-0.5 rounded font-mono"
                  title={owaspMeta[id as OwaspId].label}
                >
                  {id}
                </span>
              ))}
              {!dork.needsDomain && (
                <span class="text-xs text-teal-400 bg-teal-400/10 border border-teal-400/20 px-2 py-0.5 rounded">
                  no domain
                </span>
              )}
            </div>

            <p class="text-xs text-zinc-400 leading-relaxed mb-3">{dork.description}</p>

            <div class="relative bg-zinc-950 border border-zinc-800 rounded-lg">
              <code class="dork-query block text-xs font-mono text-green-400 px-3 py-3 pr-10 whitespace-pre-wrap break-all leading-relaxed">
                {dork.query}
              </code>
              <button
                class="copy-btn absolute top-2 right-2 p-1.5 rounded text-zinc-500 hover:text-zinc-200 hover:bg-zinc-800 transition"
                title="Copy to clipboard"
                aria-label="Copy dork"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="copy-icon w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                  <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                </svg>
                <svg xmlns="http://www.w3.org/2000/svg" class="check-icon w-3.5 h-3.5 hidden text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </button>
            </div>

            <div class="mt-3 flex gap-2">
              <a
                class="dork-link flex-1 text-center text-xs font-medium py-2 px-3 bg-green-500/10 hover:bg-green-500/20 border border-green-500/20 hover:border-green-500/40 text-green-400 rounded-lg transition"
                href={`https://www.google.com/search?q=${encodeURIComponent(dork.query)}`}
                target="_blank"
                rel="noopener noreferrer"
              >
                Google →
              </a>
              <a
                class="ddg-link flex-1 text-center text-xs font-medium py-2 px-3 bg-orange-500/10 hover:bg-orange-500/20 border border-orange-500/20 hover:border-orange-500/40 text-orange-400 rounded-lg transition"
                href={`https://duckduckgo.com/?q=${encodeURIComponent(dork.query)}`}
                target="_blank"
                rel="noopener noreferrer"
              >
                DuckDuckGo →
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Empty state -->
    <div id="empty-state" class="hidden text-center py-20">
      <p class="text-4xl mb-3">🔎</p>
      <p class="text-zinc-400 font-medium">No dorks match your filters.</p>
      <p class="text-zinc-600 text-sm mt-1">Try adjusting the category, severity, or search term.</p>
    </div>

    <!-- Attribution footer -->
    <div class="border-t border-zinc-800 py-6 mt-8">
      <div class="flex flex-wrap gap-4 items-center justify-between text-xs text-zinc-600">
        <span>Original dork list by <a href="https://github.com/TakSec/google-dorks-bug-bounty" target="_blank" rel="noopener" class="hover:text-zinc-400 transition underline underline-offset-2">TakSec</a></span>
        <div class="flex gap-4">
          <a href="https://github.com/TakSec/google-dorks-bug-bounty" target="_blank" rel="noopener" class="hover:text-zinc-400 transition">Original Repo</a>
          <a href="https://github.com/lutfumertceylan/top25-parameter" target="_blank" rel="noopener" class="hover:text-zinc-400 transition">Top25 Params</a>
          <a href="https://github.com/Proviesec/google-dorks" target="_blank" rel="noopener" class="hover:text-zinc-400 transition">Proviesec Dorks</a>
        </div>
      </div>
    </div>

  </div>
</Layout>

<style>
  .category-btn {
    color: rgb(113 113 122);
    border-color: rgb(39 39 42);
    background: transparent;
  }
  .category-btn:hover {
    color: rgb(228 228 231);
    border-color: rgb(63 63 70);
  }
  .category-btn.active {
    color: rgb(74 222 128);
    border-color: rgba(74, 222, 128, 0.3);
    background: rgba(74, 222, 128, 0.08);
  }
  .severity-btn {
    color: rgb(113 113 122);
    border-color: rgb(39 39 42);
    background: transparent;
  }
  .severity-btn:hover { color: rgb(228 228 231); }
  .severity-btn.active:not([data-severity="all"]) { outline: 2px solid rgba(255,255,255,0.2); }
  .severity-btn[data-severity="all"].active {
    color: rgb(74 222 128);
    border-color: rgba(74, 222, 128, 0.3);
    background: rgba(74, 222, 128, 0.08);
  }
  .owasp-btn {
    color: rgb(113 113 122);
    border-color: rgb(39 39 42);
    background: transparent;
    font-family: ui-monospace, monospace;
  }
  .owasp-btn:hover {
    color: rgb(196 181 253);
    border-color: rgba(139, 92, 246, 0.3);
  }
  .owasp-btn.active {
    color: rgb(167 139 250);
    border-color: rgba(139, 92, 246, 0.4);
    background: rgba(139, 92, 246, 0.1);
  }
</style>

<script>
  let activeCat   = 'all';
  let activeSev   = 'all';
  let activeOwasp = 'all';
  let searchTerm  = '';
  let domains: string[] = [];

  const domainInput  = document.getElementById('domain-input') as HTMLInputElement;
  const clearBtn     = document.getElementById('clear-domain') as HTMLButtonElement;
  const searchInput  = document.getElementById('search-input') as HTMLInputElement;
  const catBtns      = document.querySelectorAll<HTMLButtonElement>('.category-btn');
  const sevBtns      = document.querySelectorAll<HTMLButtonElement>('.severity-btn');
  const owaspBtns    = document.querySelectorAll<HTMLButtonElement>('.owasp-btn');
  const cards        = document.querySelectorAll<HTMLElement>('.dork-card');
  const emptyState   = document.getElementById('empty-state') as HTMLElement;
  const visCountBar  = document.getElementById('visible-count-bar') as HTMLSpanElement;

  function applyDomains() {
    cards.forEach((card) => {
      const original    = card.dataset.originalQuery ?? '';
      const needsDomain = card.dataset.needsDomain === 'true';
      const codeEl      = card.querySelector<HTMLElement>('.dork-query')!;
      const linkEl      = card.querySelector<HTMLAnchorElement>('.dork-link')!;
      const ddgLinkEl   = card.querySelector<HTMLAnchorElement>('.ddg-link')!;

      let updated = original;
      if (needsDomain && domains.length > 0) {
        const primary = domains[0];
        if (domains.length === 1) {
          updated = original
            .replace(/site:\*\.example\.com/g, `site:*.${primary}`)
            .replace(/site:example\.com/g, `site:${primary}`)
            .replace(/"example\.com"/g, `"${primary}"`)
            .replace(/intext:"example\.com"/g, `intext:"${primary}"`);
        } else {
          updated = original
            .replace(/site:\*\.example\.com/g, domains.map((d) => `site:*.${d}`).join(' | '))
            .replace(/site:example\.com/g, domains.map((d) => `site:${d}`).join(' | '))
            .replace(/"example\.com"/g, domains.map((d) => `"${d}"`).join(' | '))
            .replace(/intext:"example\.com"/g, domains.map((d) => `intext:"${d}"`).join(' | '));
        }
      }

      codeEl.textContent = updated;
      linkEl.href = `https://www.google.com/search?q=${encodeURIComponent(updated)}`;
      ddgLinkEl.href = `https://duckduckgo.com/?q=${encodeURIComponent(updated)}`;
      card.dataset.currentQuery = updated;
    });
  }

  function applyFilters() {
    let visible = 0;
    cards.forEach((card) => {
      const cat     = card.dataset.category ?? '';
      const sev     = card.dataset.severity ?? '';
      const title   = card.dataset.title ?? '';
      const desc    = card.dataset.description ?? '';
      const tags    = card.dataset.tags ?? '';
      const query   = (card.dataset.currentQuery ?? card.dataset.originalQuery ?? '').toLowerCase();
      const owaspIds = card.dataset.owasp ?? '';
      const catOk   = activeCat === 'all' || cat === activeCat;
      const sevOk   = activeSev === 'all' || sev === activeSev;
      const owaspOk = activeOwasp === 'all' || owaspIds.split(' ').includes(activeOwasp);
      const needle  = searchTerm.toLowerCase();
      const srchOk  = !needle || title.includes(needle) || desc.includes(needle) || query.includes(needle) || tags.includes(needle) || owaspIds.toLowerCase().includes(needle);
      const show = catOk && sevOk && owaspOk && srchOk;
      card.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    visCountBar.textContent = String(visible);
    emptyState.classList.toggle('hidden', visible > 0);
  }

  document.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const card  = btn.closest<HTMLElement>('.dork-card')!;
      const query = card.dataset.currentQuery ?? card.dataset.originalQuery ?? '';
      await navigator.clipboard.writeText(query);
      const copyIcon  = btn.querySelector<SVGElement>('.copy-icon')!;
      const checkIcon = btn.querySelector<SVGElement>('.check-icon')!;
      copyIcon.classList.add('hidden');
      checkIcon.classList.remove('hidden');
      btn.classList.add('text-green-400');
      setTimeout(() => {
        copyIcon.classList.remove('hidden');
        checkIcon.classList.add('hidden');
        btn.classList.remove('text-green-400');
      }, 1800);
    });
  });

  domainInput.addEventListener('input', () => {
    domains = domainInput.value.split(',').map((s) => s.trim()).filter(Boolean);
    applyDomains();
    applyFilters();
  });

  clearBtn.addEventListener('click', () => {
    domainInput.value = '';
    domains = [];
    applyDomains();
    applyFilters();
  });

  searchInput.addEventListener('input', () => {
    searchTerm = searchInput.value;
    applyFilters();
  });

  catBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      activeCat = btn.dataset.category ?? 'all';
      catBtns.forEach((b) => b.classList.toggle('active', b === btn));
      applyFilters();
    });
  });

  sevBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      activeSev = btn.dataset.severity ?? 'all';
      sevBtns.forEach((b) => b.classList.toggle('active', b === btn));
      applyFilters();
    });
  });

  owaspBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      activeOwasp = btn.dataset.owasp ?? 'all';
      owaspBtns.forEach((b) => b.classList.toggle('active', b === btn));
      applyFilters();
    });
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === '/' && document.activeElement?.tagName !== 'INPUT') {
      e.preventDefault();
      searchInput.focus();
    }
  });

  applyFilters();
</script>
